rules_version = '2';

// Submission working-photos. Each student may read, write and delete ONLY the
// photos under their own /submissions/{uid}/... path. Writes are capped at 5MB
// and must be images. Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    match /submissions/{userId}/{paperId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
    // Everything else is denied by default.
  }
}
