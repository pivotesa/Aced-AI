{
  "outputDirectory": "public",

  "functions": {
    "api/generate-paper.js": {
      "maxDuration": 300
    },
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/app",        "destination": "/app.html" },
    { "source": "/app/(.*)",   "destination": "/app.html" },
    { "source": "/admin",      "destination": "/admin.html" },
    { "source": "/admin/(.*)", "destination": "/admin.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
